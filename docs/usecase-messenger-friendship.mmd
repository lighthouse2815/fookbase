flowchart LR

    classDef actor fill:#fff7e8,stroke:#8b6f47,color:#1f2937,stroke-width:1.2px;
    classDef usecase fill:#eef4fb,stroke:#355c7d,color:#1f2937,stroke-width:1.1px;

    WEB["Actor: User Web"]
    MOBILE["Actor: User Mobile"]

    subgraph SYS["Use Case Chinh - Friendship va Messenger"]
        direction TB
        UC_SEARCH([Tim kiem nguoi dung / contact])
        UC_REQUEST([Gui, chap nhan, tu choi loi moi ket ban])
        UC_RELATION([Unfriend / block / unblock])
        UC_CONV([Tao hoi thoai private / group])
        UC_HISTORY([Xem danh sach hoi thoai va lich su tin nhan])
        UC_REST([Gui tin nhan qua REST API])
        UC_STOMP([Gui/nhan tin nhan realtime STOMP WebSocket])
        UC_GROUP([Quan ly thanh vien nhom chat])
        UC_PRESENCE([Theo doi trang thai online/presence])
    end

    WEB --> UC_SEARCH
    WEB --> UC_REQUEST
    WEB --> UC_RELATION
    WEB --> UC_CONV
    WEB --> UC_HISTORY
    WEB --> UC_REST
    WEB --> UC_STOMP
    WEB --> UC_GROUP
    WEB --> UC_PRESENCE

    MOBILE --> UC_SEARCH
    MOBILE --> UC_REQUEST
    MOBILE --> UC_RELATION
    MOBILE --> UC_CONV
    MOBILE --> UC_HISTORY
    MOBILE --> UC_REST
    MOBILE --> UC_STOMP
    MOBILE --> UC_GROUP
    MOBILE --> UC_PRESENCE

    class WEB,MOBILE actor;
    class UC_SEARCH,UC_REQUEST,UC_RELATION,UC_CONV,UC_HISTORY,UC_REST,UC_STOMP,UC_GROUP,UC_PRESENCE usecase;
