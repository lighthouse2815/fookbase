flowchart LR

    classDef actor fill:#fff7e8,stroke:#8b6f47,color:#1f2937,stroke-width:1.2px;
    classDef usecase fill:#eef4fb,stroke:#355c7d,color:#1f2937,stroke-width:1.1px;

    USER["Actor: User Web"]
    ADMIN["Actor: Admin"]

    subgraph SYS["Use Case Chinh - Admin va Realtime Games"]
        direction TB
        UC_ROOM([Tao room game / tham gia room])
        UC_PLAY([Choi game realtime: chess, caro, snake, flappy])
        UC_RESULT([Nhan ket qua, diem so, trang thai tran])
        UC_REPORTS([Xem va xu ly report: post, story, user, comment])
        UC_USERS([Tim kiem user va cap nhat trang thai tai khoan])
        UC_AUDIT([Xem audit log va dashboard quan tri])
        UC_ADMINPROFILE([Quan ly profile admin])
    end

    USER --> UC_ROOM
    USER --> UC_PLAY
    USER --> UC_RESULT

    ADMIN --> UC_REPORTS
    ADMIN --> UC_USERS
    ADMIN --> UC_AUDIT
    ADMIN --> UC_ADMINPROFILE

    class USER,ADMIN actor;
    class UC_ROOM,UC_PLAY,UC_RESULT,UC_REPORTS,UC_USERS,UC_AUDIT,UC_ADMINPROFILE usecase;
