@startuml
title Use Case Chinh - Admin (Footbase)

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultFontName "Times New Roman"
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #EEF4FB
  BorderColor #355C7D
  ArrowColor #355C7D
}
skinparam rectangle {
  BackgroundColor #FFF9EE
  BorderColor #8B6F47
}

actor Admin
actor "Notification Service" as Notify

rectangle "FOOTBASE ADMIN SYSTEM" {
  package "Admin Authentication" {
    usecase "Dang nhap admin" as UC_AdminLogin
    usecase "Lam moi token" as UC_AdminRefresh
    usecase "Dang xuat" as UC_AdminLogout
  }

  package "Content Moderation" {
    usecase "Xem danh sach bao cao" as UC_ReportList
    usecase "Xem chi tiet bao cao" as UC_ReportDetail
    usecase "Xu ly bao cao" as UC_ReportHandle
    usecase "An / xoa noi dung vi pham" as UC_ContentAction
    usecase "Canh cao / khoa tai khoan" as UC_UserAction
  }

  package "User Management" {
    usecase "Tim kiem nguoi dung" as UC_UserSearch
    usecase "Cap nhat trang thai tai khoan" as UC_UserStatus
    usecase "Xem ho so nguoi dung" as UC_UserProfile
  }

  package "Monitoring & Audit" {
    usecase "Xem dashboard quan tri" as UC_Dashboard
    usecase "Xem audit log" as UC_Audit
    usecase "Thong ke xu huong vi pham" as UC_Stats
  }
}

Admin --> UC_AdminLogin
Admin --> UC_AdminRefresh
Admin --> UC_AdminLogout

Admin --> UC_ReportList
Admin --> UC_ReportDetail
Admin --> UC_ReportHandle
Admin --> UC_UserSearch
Admin --> UC_UserStatus
Admin --> UC_UserProfile
Admin --> UC_Dashboard
Admin --> UC_Audit
Admin --> UC_Stats

UC_ReportHandle .> UC_ReportDetail : <<include>>
UC_ReportHandle .> UC_ContentAction : <<extend>>
UC_ReportHandle .> UC_UserAction : <<extend>>
UC_UserStatus .> UC_UserSearch : <<include>>
UC_Dashboard .> UC_Stats : <<include>>

UC_ReportHandle .> Notify : <<uses>>
UC_UserStatus .> Notify : <<uses>>

@enduml
