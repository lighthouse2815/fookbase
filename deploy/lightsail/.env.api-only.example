# Frontend origin allowed by both backends.
# Example: https://app.example.com
APP_ORIGIN=https://app.example.com

# Host port for the API gateway on the Lightsail instance.
API_GATEWAY_PORT=80

# Keep false for plain HTTP testing. Switch to true when the request reaches
# the gateway over HTTPS and X-Forwarded-Proto is preserved by your proxy/CDN.
C_SHARP_ENABLE_HTTPS_REDIRECTION=false

# External PostgreSQL for the C# API.
# Example:
# Host=ep-xxxx.ap-southeast-1.aws.neon.tech;Port=5432;Database=fookbase;Username=user;Password=pass;SSL Mode=Require;Trust Server Certificate=true
C_SHARP_DB_CONNECTION=

# External MySQL-compatible database for the Java API.
# If you use TiDB Cloud Starter, use the JDBC URL shown in the TiDB console and
# keep TLS enabled.
JAVA_DB_URL=
JAVA_DB_USERNAME=
JAVA_DB_PASSWORD=

# External Redis
REDIS_HOST=
REDIS_PORT=6379

# External RabbitMQ for read-model events.
# Leave both READ_MODEL flags false if you want to demo first without RabbitMQ.
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VIRTUAL_HOST=/
READ_MODEL_EVENTS_ENABLED=false
READ_MODEL_CONSUMER_ENABLED=false
READ_MODEL_EXCHANGE=fookbase.domain.events
READ_MODEL_QUEUE_NAME=fookbase.read-model.csharp
READ_MODEL_PREFETCH_COUNT=32

# Auth/JWT secrets
C_SHARP_JWT_SECRET_KEY=
JAVA_JWT_SIGNER_KEY=
JAVA_RESET_TOKEN_SECRET=

# Optional integrations
MAIL_USERNAME=
MAIL_PASSWORD=
GOOGLE_OAUTH_CLIENT_ID=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UPLOAD_FOLDER=fookbase/posts
