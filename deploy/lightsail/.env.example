# Public endpoint (IP or domain) used when building frontend.
# Example:
# APP_ORIGIN=http://54.255.10.20
# APP_ORIGIN=https://app.yourdomain.com
APP_ORIGIN=http://YOUR_LIGHTSAIL_PUBLIC_IP

# Frontend build-time env
VITE_API_BASE_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP
VITE_JAVA_API_BASE_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP
VITE_GOOGLE_WEB_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=

# Web port on host
WEB_PORT=80

# C# PostgreSQL
POSTGRES_DB=fookbase
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres

# Java MySQL
MYSQL_ROOT_PASSWORD=change_me_mysql_root
MYSQL_DATABASE=chat_app
MYSQL_USER=chat_app_user
MYSQL_PASSWORD=change_me_mysql_user

# RabbitMQ shared by Java (publisher) and C# (consumer)
RABBITMQ_DEFAULT_USER=fookbase
RABBITMQ_DEFAULT_PASS=change_me_rabbitmq
READ_MODEL_EVENTS_ENABLED=true
READ_MODEL_CONSUMER_ENABLED=true
READ_MODEL_EXCHANGE=fookbase.domain.events
READ_MODEL_QUEUE_NAME=fookbase.read-model.csharp
READ_MODEL_PREFETCH_COUNT=32

# Auth/JWT secrets
C_SHARP_JWT_SECRET_KEY=change_me_csharp_jwt_secret_key_at_least_32_chars
JAVA_JWT_SIGNER_KEY=change_me_java_jwt_signer_key_at_least_32_chars
JAVA_RESET_TOKEN_SECRET=change_me_java_reset_token_secret

# Optional integrations
MAIL_USERNAME=
MAIL_PASSWORD=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UPLOAD_FOLDER=fookbase/posts
