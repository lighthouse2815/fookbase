# Frontend origin allowed by both backends.
APP_ORIGIN=https://app.example.com

# VM1 public gateway port.
API_GATEWAY_PORT=80

# Gateway upstreams.
# Keep the C# upstream as-is because api-gateway and csharp-api share VM1.
CSHARP_API_UPSTREAM=http://csharp-api:8081

# Point both values at VM2.
# Example with VM2 private IP:
# JAVA_API_UPSTREAM=http://10.0.1.25:8080
# JAVA_API_INTERNAL_BASE_URL=http://10.0.1.25:8080/api
JAVA_API_UPSTREAM=
JAVA_API_INTERNAL_BASE_URL=

# Keep false for plain HTTP testing. Switch to true only when your gateway
# receives real HTTPS and preserves X-Forwarded-Proto.
C_SHARP_ENABLE_HTTPS_REDIRECTION=false

# External PostgreSQL for the C# API.
C_SHARP_DB_CONNECTION=

# RabbitMQ is optional for the first deploy.
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VIRTUAL_HOST=/
READ_MODEL_CONSUMER_ENABLED=false
READ_MODEL_EXCHANGE=fookbase.domain.events
READ_MODEL_QUEUE_NAME=fookbase.read-model.csharp
READ_MODEL_PREFETCH_COUNT=32

# Auth/JWT secret for the C# API.
C_SHARP_JWT_SECRET_KEY=

# Optional integrations used by the C# API.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UPLOAD_FOLDER=fookbase/posts
