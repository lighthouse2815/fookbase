<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Avatar Container -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp">

            <!-- Single Avatar -->
            <ImageView
                android:id="@+id/avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_avatar"
                android:scaleType="centerCrop"
                android:contentDescription="@string/avatar"/>

            <!-- Group Avatar Overlay (member count) -->
            <TextView
                android:id="@+id/memberCount"
                android:layout_width="24dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/group_avatar_background"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:visibility="visible"
                tools:text="83" />

            <!-- Online Indicator -->
            <View
                android:id="@+id/onlineIndicator"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/online_indicator"
                android:visibility="visible" />
        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Name and Time Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/conversationName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Ngôn ngữ dư++" />

                <TextView
                    android:id="@+id/timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    tools:text="1 phút" />
            </LinearLayout>

            <!-- Message Preview and Badge Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/lastMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Bạn: anh yêu em" />

                <!-- Unread Badge -->
                <TextView
                    android:id="@+id/unreadBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/badge_background"
                    android:gravity="center"
                    android:textColor="@color/ZALO_badge_text"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="visible"
                    tools:text="1" />

                <!-- Unread Dot (for no count) -->
                <View
                    android:id="@+id/unreadDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/badge_background"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Tags Row -->
            <LinearLayout
                android:id="@+id/tagsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tagText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_background"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:drawablePadding="4dp"
                    tools:text="Gia đình" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="80dp"
        android:background="@color/ZALO_divider" />

</LinearLayout>
