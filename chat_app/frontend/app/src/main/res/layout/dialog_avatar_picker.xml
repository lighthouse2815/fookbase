<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_background"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bottom_sheet_handle" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:text="@string/update_avatar_title"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Emoji Icons Row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:id="@+id/emojiContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/emoji1"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/emoji_calendar"
                android:background="@drawable/emoji_background"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_emoji_calendar" />

            <ImageView
                android:id="@+id/emoji2"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/emoji_megaphone"
                android:background="@drawable/emoji_background_yellow"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_emoji_megaphone" />

            <ImageView
                android:id="@+id/emoji3"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/emoji_checklist"
                android:background="@drawable/emoji_background_orange"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_emoji_checklist" />

            <ImageView
                android:id="@+id/emoji4"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/emoji_image"
                android:background="@drawable/emoji_background_green"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_emoji_image" />

            <ImageView
                android:id="@+id/emoji5"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/emoji_pencil"
                android:background="@drawable/emoji_background_blue"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_emoji_pencil" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="20dp"
        android:background="@color/ZALO_divider" />

    <!-- Take Photo Option -->
    <LinearLayout
        android:id="@+id/optionTakePhoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/cd_take_photo_option">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/take_photo"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- Choose from Phone Option -->
    <LinearLayout
        android:id="@+id/optionChoosePhoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/cd_choose_photo_option">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_photo_from_phone"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

    </LinearLayout>

</LinearLayout>
