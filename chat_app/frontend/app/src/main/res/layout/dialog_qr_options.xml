<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_popup"
    android:paddingTop="12dp"
    android:paddingBottom="8dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/qr_options_title"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="12dp" />

    <!-- Option 1 -->
    <TextView
        android:id="@+id/btnEdit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/qr_edit"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:gravity="center" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2FFFFFFF" />

    <!-- Option 2 -->
    <TextView
        android:id="@+id/btnChangeQr"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/qr_change"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:gravity="center" />

    <!-- Cancel -->
    <TextView
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/qr_cancel"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_popup_cancel" />
</LinearLayout>
