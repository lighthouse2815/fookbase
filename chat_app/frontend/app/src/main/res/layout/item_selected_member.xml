<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:background="@drawable/circle_avatar"
        android:contentDescription="@string/cd_selected_member_avatar"/>

    <TextView
        android:id="@+id/tvInitials"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Remove Button -->
    <ImageView
        android:id="@+id/ivRemove"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-2dp"
        android:layout_marginEnd="-2dp"
        android:src="@drawable/ic_remove_circle"
        android:background="@color/ZALO_background_surface"
        android:contentDescription="@string/cd_remove_button"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
