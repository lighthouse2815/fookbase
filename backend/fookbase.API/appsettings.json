{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AppDbConnection": "Server=.;Database=chat_app_csharp;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "JavaApi": {
    "BaseUrl": "http://localhost:8080/api",
    "UserByIdPathTemplate": "users/{id}",
    "ProfileByUserIdPathTemplate": "profiles?userId={userId}",
    "FriendsByUserIdPathTemplate": "friendships?userId={userId}",
    "AuthRegisterPathTemplate": "auth/register",
    "AuthLoginPathTemplate": "auth/login"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Jwt": {
    "Issuer": "InteractHub",
    "Audience": "InteractHub.Client",
    "ValidateIssuer": false,
    "ValidateAudience": false,
    "SecretKey": "CHANGE_THIS_SECRET_KEY_TO_A_LONG_RANDOM_VALUE_1234567890",
    "ExpirationMinutes": 60
  }
}
