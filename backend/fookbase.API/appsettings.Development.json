{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "AppDbConnection": "Server=(localdb)\\MSSQLLocalDB;Database=fookbase;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "JavaApi": {
    "BaseUrl": "http://localhost:8080/api",
    "UserByIdPathTemplate": "users/{id}",
    "ProfileByUserIdPathTemplate": "profiles?userId={userId}",
    "FriendsByUserIdPathTemplate": "friendships?userId={userId}",
    "AuthRegisterPathTemplate": "auth/register",
    "AuthLoginPathTemplate": "auth/login"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Jwt": {
    "Issuer": "InteractHub",
    "Audience": "InteractHub.Client",
    "ValidateIssuer": false,
    "ValidateAudience": false,
    "SecretKey": "THIS_IS_A_SUPER_LONG_SECRET_KEY_1234567890_ABCDEF_XYZ",
    "ExpirationMinutes": 60
  }
}
